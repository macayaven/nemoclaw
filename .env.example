# =============================================================================
# NemoClaw — Example Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# .env is gitignored. Never commit your real .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Machine IPs (update with your actual IPs)
# Find these with `ip addr` (Linux) or `ipconfig getifaddr en0` (Mac)
# -----------------------------------------------------------------------------

# DGX Spark — primary inference host and NemoClaw gateway
SPARK_IP=192.168.1.150
SPARK_HOSTNAME=spark-caeb.local

# Mac Studio — secondary inference provider (Gemma 4 27B)
MAC_IP=192.168.1.100
MAC_HOSTNAME=mac-studio.local

# -----------------------------------------------------------------------------
# Tailscale IPs (from `tailscale ip` on each machine)
# These are used for remote access.
# -----------------------------------------------------------------------------

SPARK_TAILSCALE_IP=100.x.x.x
MAC_TAILSCALE_IP=100.x.x.x

# -----------------------------------------------------------------------------
# SSH
# The user must have SSH access to the Spark from the Mac (or vice versa).
# -----------------------------------------------------------------------------

SSH_USER=carlos
# SSH_KEY=~/.ssh/nvsync.key  # Uncomment if using a specific key (not the default)

# -----------------------------------------------------------------------------
# API Keys (optional — needed for cloud agent sandboxes)
# Leave commented out if you are only using local Ollama models.
# -----------------------------------------------------------------------------

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# -----------------------------------------------------------------------------
# Timeouts (seconds)
# Increase these on slow or high-latency networks.
# -----------------------------------------------------------------------------

# Timeout for HTTP requests to providers and the gateway
HTTP_TIMEOUT=30

# Timeout for establishing SSH connections during tests
SSH_CONNECT_TIMEOUT=10
