# =============================================================================
# NemoClaw — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
openshell-env/
.venv/

# -----------------------------------------------------------------------------
# Environment / secrets
# .env.example is intentionally NOT ignored — it is safe to commit.
# -----------------------------------------------------------------------------
.env

# -----------------------------------------------------------------------------
# IDE / editor
# -----------------------------------------------------------------------------
.vscode/
.idea/

# -----------------------------------------------------------------------------
# OS artifacts
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log

# -----------------------------------------------------------------------------
# Build artifacts
# -----------------------------------------------------------------------------
dist/
build/
*.egg-info/

# -----------------------------------------------------------------------------
# Claude Code local settings
# -----------------------------------------------------------------------------
.claude/

# -----------------------------------------------------------------------------
# Test / coverage artifacts
# -----------------------------------------------------------------------------
htmlcov/
coverage.xml
.coverage
